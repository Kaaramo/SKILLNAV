# ═══════════════════════════════════════════════════════════════════════════
# SKILLNAV — variables d'environnement (template)
# ═══════════════════════════════════════════════════════════════════════════
# Copier ce fichier en .env et remplir les valeurs réelles.
# .env est gitignored — JAMAIS commiter de vraies clés.

# ─── Anthropic / Claude (extraction Pydantic AI) ────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── MongoDB Atlas (source of truth — PRD §7) ───────────────────────────────
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=skillnav

# ─── Neo4j AuraDB (graphe — PRD §7.3) ───────────────────────────────────────
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ─── Elasticsearch Cloud (recherche + agrégations — PRD §7.4) ───────────────
ELASTIC_CLOUD_ID=
ELASTIC_API_KEY=
# Alternative URL+auth (si Cloud ID indisponible)
# ELASTIC_URL=https://...
# ELASTIC_USERNAME=elastic
# ELASTIC_PASSWORD=

# ─── Apify (LinkedIn scraping conforme — PRD §8.2) ──────────────────────────
APIFY_TOKEN=apify_api_...

# ─── Firecrawl (pages dynamiques — PRD §8.2) ────────────────────────────────
FIRECRAWL_API_KEY=fc-...

# ─── HuggingFace (optionnel — modèles publics téléchargeables sans token) ──
HF_TOKEN=hf_...

# ─── Application ────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
DEFAULT_LANGUAGE=fr

# Identification + politesse scrapers (PRD §N4)
SCRAPER_USER_AGENT=SkillnavBot/1.0 (Academic; M242 ENSA-Tetouan)
SCRAPER_RATE_LIMIT_SECONDS=5

# ─── API FastAPI ────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ─── Web (Next.js) — NEXT_PUBLIC_ exposé client ────────────────────────────
# Le front lit son propre .env dans web/.env (voir web/.env.example)
