# SKILLNAV Web — variables d'environnement (template)
# Copier en .env.local et remplir.

# URL backend FastAPI (rewrite Next.js → /api/* dans next.config.ts)
API_URL=http://localhost:8000

# URL publique exposée au client (NEXT_PUBLIC_ visible dans le bundle)
NEXT_PUBLIC_API_BASE_URL=/api
NEXT_PUBLIC_APP_NAME=SKILLNAV
NEXT_PUBLIC_DEFAULT_THEME=dark

# Telemetry (Vercel)
NEXT_TELEMETRY_DISABLED=1
