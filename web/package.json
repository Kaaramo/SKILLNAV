{
  "name": "skillnav-web",
  "version": "0.1.0",
  "private": true,
  "description": "SKILLNAV — dashboard Next.js 15 (M242 ENSA-Tétouan)",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json,md}\"",
    "generate-types": "openapi-typescript http://localhost:8000/openapi.json -o src/lib/api/types.ts"
  },
  "dependencies": {
    "next": "15.0.3",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "@tanstack/react-query": "^5.59.0",
    "@tanstack/react-query-devtools": "^5.59.0",
    "recharts": "^2.13.0",
    "@tremor/react": "^3.18.0",
    "react-force-graph-2d": "^1.27.0",
    "react-plotly.js": "^2.6.0",
    "plotly.js": "^2.35.0",
    "lucide-react": "^0.460.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.0",
    "class-variance-authority": "^0.7.0",
    "date-fns": "^4.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/node": "^22.9.0",
    "@types/react-plotly.js": "^2.6.3",
    "tailwindcss": "^4.0.0-beta.5",
    "@tailwindcss/postcss": "^4.0.0-beta.5",
    "postcss": "^8.4.49",
    "autoprefixer": "^10.4.20",
    "openapi-typescript": "^7.4.0",
    "eslint": "^9.15.0",
    "eslint-config-next": "15.0.3",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.3"
}
