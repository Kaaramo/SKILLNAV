# ═══════════════════════════════════════════════════════════════════════════
# SKILLNAV — .gitignore
# ═══════════════════════════════════════════════════════════════════════════

# ─── Secrets ────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
!.env.example
*.pem
*.key
secrets/

# ─── Python ─────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual envs
.venv/
venv/
ENV/
env/

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.hypothesis/
.tox/
.nox/

# Jupyter
.ipynb_checkpoints/
*/.ipynb_checkpoints/*
.jupyter/

# ─── Node / Next.js ─────────────────────────────────────────────────────────
node_modules/
.next/
out/
.turbo/
*.tsbuildinfo
next-env.d.ts

# ─── Design bundles (extractions temporaires depuis claude.ai/design) ───────
.design-bundle/
design-system-input/
.pnpm-debug.log*
.npm/
.yarn/

# ─── Données (PRD §16.2 — gitignored par défaut) ────────────────────────────
data/raw/
data/exports/
data/audit/
# gold_set/ reste committé (fixtures pour tests)
!data/gold_set/
data/gold_set/*.bak

# Repos externes clonés pour analyse / import secondaire (NE PAS commiter)
sources/external/
# raw/ par source = HTML/JSON brut re-dérivable, gitignored, sauf recap
sources/collected/*/raw/*
!sources/collected/*/raw/_*.json
!sources/collected/*/raw/.gitkeep

# Dumps DBs
*.dump
*.bson
*.cypher.dump

# Models téléchargés (HuggingFace cache)
.cache/huggingface/
models/

# ─── IDE ────────────────────────────────────────────────────────────────────
.idea/
.vscode/*
!.vscode/settings.json.example
*.iml
*.swp
*.swo

# ─── OS ─────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ─── Logs ───────────────────────────────────────────────────────────────────
*.log
logs/
lightning_logs/
notebooks/lightning_logs/

# ─── Caches IDE / MCP (entièrement gitignorés) ──────────────────────────────
.claude/
.firecrawl/
.playwright-mcp/

# ─── Misc ───────────────────────────────────────────────────────────────────
*.tmp
*.bak
~$*
.charte_tmp.html
_preview/
_ref/

# Fichier personnel de configuration de l'utilisateur (ex: pour les chemins locaux)
bachirou.md